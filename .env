# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-in-production
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8080
###< symfony/routing ###

###> docker ###
HTTP_PORT=8080
POSTGRES_PORT=5432
POSTGRES_DB=contact_api
POSTGRES_USER=app
POSTGRES_PASSWORD=app
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
RUN_MIGRATIONS=1
###< docker ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# Mailtrap Sandbox (put real password in .env.local — do not commit secrets)
# Format: smtp://USERNAME:PASSWORD@sandbox.smtp.mailtrap.io:2525
MAILER_DSN=
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> openrouter ###
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_TIMEOUT=30
OPENROUTER_FALLBACK_REPLY="Спасибо за ваше сообщение. Мы скоро свяжемся с вами."
###< openrouter ###

###> contact mail ###
MAIL_FROM=no-reply@example.local
MAIL_FROM_NAME="Developer Contact API"
OWNER_EMAIL=owner@example.local
###< contact mail ###
